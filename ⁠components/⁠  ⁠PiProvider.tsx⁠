"use client";

import React, {
  createContext,
  useContext,
  useEffect,
  useState,
} from "react";

declare global {
  interface Window {
    Pi?: any;
  }
}

type PiContextType = {
  ready: boolean;
  pi: any | null;
};

const PiContext = createContext<PiContextType>({
  ready: false,
  pi: null,
});

export function PiProvider({
  children,
}: {
  children: React.ReactNode;
}) {
  const [ready, setReady] = useState(false);
  const [pi, setPi] = useState<any>(null);

  useEffect(() => {
    let cancelled = false;

    async function initialize() {
      try {
        if (typeof window === "undefined") return;

        const checkSDK = () => {
          const sdk = window.Pi;

          if (!sdk) {
            return false;
          }

          try {
            sdk.init({
              version: "2.0",
              sandbox: true,
            });

            if (!cancelled) {
              setPi(sdk);
              setReady(true);
            }

            return true;
          } catch (err) {
            console.error("Pi.init failed:", err);

            if (!cancelled) {
              setReady(true);
            }

            return true;
          }
        };

        if (checkSDK()) return;

        let attempts = 0;

        const interval = setInterval(() => {
          attempts++;

          if (checkSDK() || attempts >= 20) {
            clearInterval(interval);

            if (!cancelled) {
              setReady(true);
            }
          }
        }, 500);
      } catch (err) {
        console.error(err);

        if (!cancelled) {
          setReady(true);
        }
      }
    }

    initialize();

    return () => {
      cancelled = true;
    };
  }, []);

  return (
    <PiContext.Provider
      value={{
        ready,
        pi,
      }}
    >
      {children}
    </PiContext.Provider>
  );
}

export function usePi() {
  return useContext(PiContext);
}
